{
  "name": "server",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/server.ts --outfile server",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.mjs",
    "generate:openapi": "tsx src/openapi.ts",
    "db:seed": "tsx src/database/seed.ts"
  },
  "dependencies": {
    "@eng-soft1/auth": "workspace:*",
    "@eng-soft1/db": "workspace:*",
    "@eng-soft1/env": "workspace:*",
    "@fastify/cors": "^11.0.1",
    "@fastify/swagger": "^9.7.0",
    "@scalar/fastify-api-reference": "^1.57.2",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "fastify": "^5.3.3",
    "fastify-type-provider-zod": "^6.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eng-soft1/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.21.9",
    "tsx": "^4.19.2",
    "typescript": "catalog:"
  }
}
